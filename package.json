{
  "name": "markdown-viewer",
  "private": true,
  "version": "0.3.1",
  "description": "A local-first Markdown reader and editor packaged for web and desktop.",
  "author": "Chatchai.j <chatchai.j98@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && electron .",
    "desktop:dev": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:5173 && electron . --dev-server=http://127.0.0.1:5173\"",
    "desktop:build": "npm run build && electron-builder --win nsis portable"
  },
  "build": {
    "appId": "com.chatchai98.markdownviewer",
    "productName": "Markdown Viewer",
    "directories": {
      "output": "release/V0.3.1"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "nsis": {
      "artifactName": "${productName} Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName} Portable-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  }
}
